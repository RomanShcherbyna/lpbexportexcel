APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Логотип в шапке UI: путь относительно public/ (по умолчанию public/images/logo.png)
# LPB_LOGO_PATH=images/logo.png

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Liewood retail CSV (как ручной final + Photo 1–10, курс PLN)
LIEWOOD_RETAIL_EXPORT=true
LIEWOOD_EUR_TO_PLN_RATE=4.25

# Liewood: подставлять URL фото в экспорт.
# Источник картинок: gcs (рекомендуется) или drive (legacy).
LIEWOOD_DRIVE_ENABLED=false
LIEWOOD_IMAGES_SOURCE=gcs
LIEWOOD_GCS_BUCKET=lpb-bucket
LIEWOOD_GCS_PREFIX=liewoodseason12026/
# LIEWOOD_GCS_PUBLIC_BASE_URL=https://storage.googleapis.com
# В CSV для режима "download":
# - false: обычные public URL GCS
# - true: public URL GCS + параметр response-content-disposition=attachment
# (чтобы BaseLinker скачивал по ссылке; поведение браузера зависит от поддержки GCS)
# LIEWOOD_GCS_USE_DOWNLOAD_PROXY=false
# LIEWOOD_GCS_DOWNLOAD_PROXY_TTL=604800 # оставлено для обратной совместимости

# Legacy Google Drive:
LIEWOOD_DRIVE_FOLDER_ID=1FvQTZT2ecCPDmyGMulaRPGYrILwN04NX
# LIEWOOD_DRIVE_CREDENTIALS_PATH=/absolute/path/to/credentials.json
# LIEWOOD_DRIVE_TOKEN_PATH=/absolute/path/to/token.json
# Не включайте на больших папках: сотни запросов permissions → таймаут. Лучше Python-скрипт --make-public.
LIEWOOD_DRIVE_APPLY_PUBLIC_PERMISSION_PER_FILE=false
LIEWOOD_DRIVE_MAX_EXECUTION_SECONDS=300
# LIEWOOD_DRIVE_CACHE_TTL=1800
